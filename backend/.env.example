# ==========================================
# HOLMES BACKEND ENVIRONMENT BLUEPRINT
# Copy this file to '.env' and fill in your secure values
# ==========================================

# --- Security ---
# Generate a secure 32-byte hex string (e.g., using `python -c "import secrets; print(secrets.token_hex(32))"`)
SECRET_KEY=your_generated_secret_key_here

# --- Database (MySQL) ---
DB_HOST="localhost"
DB_NAME="Holmes"
DB_USER="holmes_admin"
# Do not commit your real password!
DB_PASSWORD=your_local_db_password

# --- External APIs ---
# Google Gemini API Key (Get this from Google Cloud Console)
GOOGLE_API_KEY=your_google_api_key_here

# --- Frontend Connection ---
# Comma separated list of allowed origins for CORS
CORS_ORIGINS="http://localhost:5173,http://192.168.56.1:5173,http://192.168.1.51:5173"

# --- Local AI Model Configuration ---
USE_LOCAL_MODEL=False
# Default to gemma3:4b, can specify other local models (e.g., llama3) if needed
MODEL_NAME=gemma3:4b
OLLAMA_API_URL=http://localhost:11434/api/generate